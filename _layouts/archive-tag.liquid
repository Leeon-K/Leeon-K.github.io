---
layout: default
---

{% assign tag_name = page.url | split: '/' | last %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title"><i class="fa-solid fa-hashtag fa-sm"></i> {{ tag_name }}</h1>
    <p class="post-description">an archive of posts with this tag</p>
  </header>

  <article class="archive">
    <div class="table-responsive">
      <table class="table table-sm table-borderless">
        {% assign tag_found = false %}

        <!-- HTML 博客（从 _data/blogs.yml） -->
        {% if site.data.blogs %}
          {% for blog in site.data.blogs %}
            {% if blog.tags %}
              {% for tag in blog.tags %}
                {% assign tag_slug = tag | slugify %}
                {% if tag_slug == tag_name %}
                  {% assign tag_found = true %}
                  <tr>
                    <th scope="row">{{ blog.date | date: '%b %d, %Y' }}</th>
                    <td>
                      <a class="post-link" href="{{ blog.file | relative_url }}">{{ blog.title }}</a>
                    </td>
                  </tr>
                {% endif %}
              {% endfor %}
            {% endif %}
          {% endfor %}
        {% endif %}

        {% unless tag_found %}
        <tr>
          <td>No posts found with this tag.</td>
        </tr>
        {% endunless %}
      </table>
    </div>
  </article>
</div>